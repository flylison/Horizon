{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-ai/DeepSeek-V3",
    "base_url": "https://api.siliconflow.cn/v1",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": ["zh", "en"],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 5
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vlmm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-cookbook",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 50,
      "min_score": 100,
      "keywords": ["AI", "LLM", "machine learning", "HR", "organization", "management"]
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "36kr AI",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "AI Weekly",
        "url": "https://aiweekly.co/latest.atom",
        "enabled": true,
        "category": "ai-newsletter"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "humanresources",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 10,
          "min_score": 20
        },
        {
          "subreddit": "OrganizationDevelopment",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 10,
          "min_score": 10
        },
        {
          "subreddit": "recruiting",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 10,
          "min_score": 20
        },
        {
          "subreddit": "work",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 10,
          "min_score": 20
        },
        {
          "subreddit": "management",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false
  }
}

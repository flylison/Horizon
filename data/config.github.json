{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-ai/DeepSeek-V3",
    "base_url": "https://api.siliconflow.cn/v1",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": ["zh", "en"],
    "analysis_concurrency": 3,
    "enrichment_concurrency": 3
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": false
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-cookbook",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80,
      "keywords": [
        "AI HR",
        "AI management",
        "AI organization",
        "AI recruiting",
        "AI workplace",
        "LLT productivity",
        "AI leadership",
        "AI team",
        "AI culture",
        "remote work AI",
        "HR tech",
        "future of work"
      ]
    },
    "rss": [
      {
        "name": "36kr AI+商业",
        "url": "https://#6kr.com/feed",
        "enabled": true,
        "category": "tech-business"
      },
      {
        "name": "量子位",
        "url": "https://www.qbitai.com/feed",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "机器之心",
        "url": "https://www.jiqizhixin.com/rss",
        "enabled": true,
        "category": "ai-research"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "humanresources",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 5,
          "min_score": 30
        },
        {
          "subreddit": "recruiting",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 5,
          "min_score": 30
        },
        {
          "subredddit": "remotework",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 5,
          "min_score": 20
        },
        {
          "subredddit": "productivity",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 5,
          "min_score": 30
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 5,
          "min_score": 50
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    }
  },
  "filtering": {
    "ai_score_threshold": 7.5,
    "time_window_hours": 72
  },
  "webhook": {
    "enabled": false
  }
}
